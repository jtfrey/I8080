 * project.
 */

#ifndef __I8080CONFIG_H__
#define __I8080CONFIG_H__

#include <curses.h>
#include <stdio.h>
#include <stdint.h>
#include <stdlib.h>
#include <stdbool.h>
#include <stdarg.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/types.h>
#include <fcntl.h>
#include <unistd.h>
#include <limits.h>
#include <math.h>
#include <errno.h>

#define I8080_VERSION_STRING "@PROJECT_VERSION@"
#define I8080_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define I8080_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define I8080_VERSION_PATCH @PROJECT_VERSION_PATCH@

extern const char     *I8080VersionString;
extern const unsigned I8080VersionMajor;
extern const unsigned I8080VersionMinor;
extern const unsigned I8080VersionPatch;

/*
 * Does this system's termios include the force-to-uppercase
 * output flag?
 */
#cmakedefine HAS_TERMIOS_OLCUC

/*
 * Does this system have mmap?
 */
#cmakedefine HAS_MMAP

/*
 * Native OS
 */
#cmakedefine I8080_OS_MACOSX
#cmakedefine I8080_OS_LINUX

/*
 * Does this compiler provide the __builtin_parity
 * function?
 */
#cmakedefine HAS_BUILTIN_PARITY
#ifdef HAS_BUILTIN_PARITY
#   define I8080Parity(X) (! __builtin_parity(X))
#else
    /* Kernighan's bit counter */
    static inline
    int
    I8080Parity(
        int     X
    )
    {
        int     n_bits = 0;
        while (X) X &= (X - 1), n_bits++;
        return (n_bits & 0b1) == 0;
    }
#endif

#cmakedefine I8080_STRIP_DEBUGGING

#cmakedefine I8080_MEMORY_ENABLE_INLINING

#cmakedefine I8080_SYSTEM_ENABLE_INTERRUPT_API

#cmakedefine I8080_LOGGING_USE_PRETTY_FUNCTION
#ifdef I8080_LOGGING_USE_PRETTY_FUNCTION
#   define LOGGING_FUNC __PRETTY_FUNCTION__
#else
#   define LOGGING_FUNC __func__
#endif

/**
 * Byte size of a file by name/path
 * @param filename      the file to query
 * @return              the length of the file or zero if an error
 *                      occurred
 */
off_t I8080SizeOfNamedFile(const char *filename);

/**
 * Byte size of an open stdio file
 * @param fptr          the stdio file to query
 * @return              the length of the file or zero if an error
 *                      occurred
 */
off_t I8080SizeofFilePtr(FILE *fptr);

/**
 * Byte size of an open file descriptor
 * @param fd            the file descriptor to query
 * @return              the length of the file or zero if an error
 *                      occurred
 */
off_t I8080SizeOfFileDescriptor(int fd);

#endif /* __I8080CONFIG_H__ */
