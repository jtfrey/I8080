    13       			;
    14       			;  If E = (1 + 1 + … + 1), then
    15       			;  D * E = D * (1 + 1 + … + 1)
    16       			;        = D + D + … + D
    17       			;
    18       			; The 8-bit multiplier and multiplicand are in
    19       			; registers D and E.  On exit, the pair DE
    20       			; has the (possibly) 16-bit product.
    21       			;
    22 11    0408 C5		mltalg1:        push        bc          ; we'll clobber BC and HL
    23 11    0409 E5		                push        hl
    24  7    040A 26 00	                mvi         h, 0h       ; HL <- 0000h
    25  7    040C 2E 00	                mvi         l, 0h
    26  5    040E 42		                mov         b, d        ; use B as our loop counter
    27       			                                        ; holding D...
    28  7    040F 16 00	                mvi         d, 0h       ; ..and zero-out the MSB of
    29       			                                        ; DE
    30  5    0411 04		                inr         b           ; we can only catch multiply
    31       			                                        ; by zero if we force a test
    32  5    0412 05		mltalg1_1:      dcr         b           ; of B == 0 by incrementing
    33       			                                        ; then decrementing
    34 10    0413 CA 1A 04	                jz          mltalg1_2   ; B == 0, all done
    35 10    0416 19		                dad         de          ; HL += DE
    36 10    0417 C3 12 04	                jmp         mltalg1_1   ; next iteration
    37  4    041A EB		mltalg1_2:      xchg                    ; DE <=> HL
    38 10    041B E1		                pop         hl          ; restore clobbered registers
    39 10    041C C1		                pop         bc          ; and return with the product
    40 10    041D C9		                ret                     ; in DE
    41
    42
    43       			;
    44       			;  D * E = D * Sum(i=0…7, E_i * 2^i)
    45       			;        = Sum(i=0…7, E_i * D * 2^i)
    46       			;        = Sum(i=0…7, E_i * (D << i))
    47       			; Since E_i will be 0/1, the multiplication
    48       			; is a sum of shifted copies of the multiplier.
    49       			;
    50       			; The 8-bit multiplier and multiplicand are in
    51       			; registers D and E.  On exit, the pair DE
    52       			; has the (possibly) 16-bit product.
    53       			;
    54 11    041E F5		mltalg2:        push        psw         ; we'll clobber all registers
    55 11    041F C5		                push        bc
    56 11    0420 E5		                push        hl
    57  7    0421 26 00	                mvi         h, 0h       ; HL <- 0000h
    58  7    0423 2E 00	                mvi         l, 0h
    59  7    0425 06 00	                mvi         b, 0h       ; load the multiplicand, E, into BC
    60  5    0427 4B		                mov         c, e
    61  5    0428 7A		                mov         a, d        ; move the multiplier, D, to A
    62  7    0429 16 08	                mvi         d, 8        ; now use D as our loop counter
    63  4    042B 1F		mltalg2_1:      rar                     ; A >> 1 -> carry
    64 10    042C D2 30 04	                jnc         mltalg2_2   ; do not add this factor
    65 10    042F 09		                dad         bc          ; HL += BC
    66 11    0430 F5		mltalg2_2:      push        psw         ; save A
    67  4    0431 AF		                xra         a           ; clear carry
    68  5    0432 79		                mov         a, c
    69  4    0433 17		                ral                     ; carry <- c << 1
    70  5    0434 4F		                mov         c, a
    71  5    0435 78		                mov         a, b
    72  4    0436 17		                ral                     ; b << 1 <- carry
    73  5    0437 47		                mov         b, a        ; thus, BC = BC * 2
    74 10    0438 F1		                pop         psw         ; restore A (the shifted multiplier)
    75  5    0439 15		                dcr         d           ; decrement counter and
    76 10    043A F2 2B 04	                jp          mltalg2_1   ; go do another round
    77  4    043D EB		                xchg                    ; DE <=> HL
    78 10    043E E1		                pop         hl          ; restore clobbered registers
    79 10    043F C1		                pop         bc          ; and return with the product
    80 10    0440 F1		                pop         psw         ; in DE
    81 10    0441 C9		                ret
