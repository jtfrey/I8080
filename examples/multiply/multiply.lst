    83
    84
    85       			;
    86       			; The 8-bit multiplier and multiplicand are in
    87       			; registers D and E.  On exit, the pair DE
    88       			; has the (possibly) 16-bit product.
    89       			;
    90       			; This algorithm selects the minimum value as the
    91       			; multiplier, since that accelerates both the
    92       			; repeated addition and factors of 2.  If the
    93       			; muliplier is < 16, the repeated addition
    94       			; algorithm is used; otherwise, factors of 2 is
    95       			; employed.
    96       			;
    97 11    0442 F5		mltalg3:        push        psw         ; we'll clobber all registers
    98 11    0443 C5		                push        bc
    99 11    0444 E5		                push        hl
   100  5    0445 7A		                mov         a, d        ; A <- D
   101  4    0446 BB		                cmp         e
   102 10    0447 F2 4D 04	                jp          swap        ; D >= E
   103 10    044A DA 4F 04	                jc          choosealg   ; D < E
   104  5    044D 7B		swap:           mov         a, e        ; E is the smaller value
   105  5    044E 5A		                mov         e, d        ; swap D into E
   106       			                ;
   107       			                ; At this point the multipler is in A
   108       			                ; and the multiplicand is in E
   109  7    044F 16 00	choosealg:      mvi         d, 0h       ; DE contains the 16-bit
   110       			                                        ; multiplicand now
   111
   112  7    0451 26 00	                mvi         h, 0h       ; HL <- 0000h
   113  7    0453 2E 00	                mvi         l, 0h
   114  7    0455 FE 16	                cpi         ADDTHRESH   ; is our multiplier < 16?
   115 10    0457 F2 5D 04	                jp          fctr2       ; >= 16
   116 10    045A DA 7A 04	                jc          repaddalg   ; < 16 (when A has bit 7 set)
   117       			                
   118 11    045D F5		fctr2:          push        psw
   119  7    045E 3E 32	                mvi         a, '2'
   120 10    0460 D3 00	                out         0
   121 10    0462 F1		                pop         psw
   122  7    0463 06 08	                mvi         b, 8        ; now use D as our loop counter
   123  4    0465 1F		nextfactor:     rar                     ; A >> 1 -> carry
   124 10    0466 D2 6A 04	                jnc         rotmltplcnd ; do not add this factor
   125 10    0469 19		                dad         de          ; HL += DE
   126 11    046A F5		rotmltplcnd:    push        psw         ; save A
   127  4    046B AF		                xra         a           ; clear carry
   128  5    046C 7B		                mov         a, e
   129  4    046D 17		                ral                     ; carry <- E << 1
   130  5    046E 5F		                mov         e, a
   131  5    046F 7A		                mov         a, d
   132  4    0470 17		                ral                     ; D << 1 <- carry
   133  5    0471 57		                mov         d, a        ; thus, DE = DE * 2
   134 10    0472 F1		                pop         psw         ; restore A (the shifted multiplier)
   135  5    0473 05		                dcr         b           ; decrement counter and
   136 10    0474 F2 65 04	                jp          nextfactor  ; go do another round
   137 10    0477 C3 89 04	                jmp         mltplyexit
   138
   139 11    047A F5		repaddalg:      push        psw
   140  7    047B 3E 41	                mvi         a, 'A'
   141 10    047D D3 00	                out         0
   142 10    047F F1		                pop         psw
   143  5    0480 3C		                inr         a
   144  5    0481 3D		repaddnext:     dcr         a
   145 10    0482 CA 89 04	                jz          mltplyexit
   146 10    0485 19		                dad         de
   147 10    0486 C3 81 04	                jmp         repaddnext
   148       			                
   149  4    0489 EB		mltplyexit:     xchg                    ; DE <=> HL
   150 10    048A E1		                pop         hl          ; restore clobbered registers
   151 10    048B C1		                pop         bc          ; and return with the product
   152 10    048C F1		                pop         psw         ; in DE
   153 10    048D C9		                ret


